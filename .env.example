# ── HubSpot ────────────────────────────────────────────────────────────────────
# Private App access token. Create at: Settings → Integrations → Private Apps.
# Required scopes: crm.objects.companies.read, crm.objects.deals.read,
#                  crm.objects.contacts.read, crm.schemas.deals.read
HUBSPOT_ACCESS_TOKEN=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# EA Technology's portal is on EU1 data residency:
HUBSPOT_API_BASE=https://api-eu1.hubapi.com

# ── Security ───────────────────────────────────────────────────────────────────
# Protects /api/cron/sync. On Vercel, setting CRON_SECRET makes Vercel Cron
# send it automatically as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=generate-a-long-random-string

# Optional: HTTP Basic Auth password for the dashboard UI (any username).
# Leave unset to disable auth (e.g. for local use).
DASHBOARD_PASSWORD=

# ── Tuning (optional) ──────────────────────────────────────────────────────────
# Days before deal creation that a marketing touch still counts as influence.
INFLUENCE_LOOKBACK_DAYS=730

# ── HubSpot company lists as touch sources (optional) ──────────────────────────
# Map HubSpot company-list IDs (e.g. Buyer Intent based active lists) to
# influence channels. Members become company-level touches dated when they
# joined the list. Requires crm.lists.read scope on the Private App.
# Format: <listId>:<channel>[,<listId>:<channel>...]
# Channels: organic_social_visibility | linkedin_visibility | referral | other
# HUBSPOT_LIST_TOUCHES=301:organic_social_visibility

# ── LinkedIn Ads API (optional — automated paid company visibility) ───────────
# Replaces the manual Company Engagement Report CSV for the PAID side.
# Setup: developer.linkedin.com → create app → request "Advertising API"
# (Development tier is enough for reporting) → add redirect URL
# http://localhost:8976/callback → run: npm run linkedin-auth
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REFRESH_TOKEN=        # preferred: sync auto-refreshes access tokens
# LINKEDIN_ACCESS_TOKEN=         # alternative: direct token (~60 days)
# LINKEDIN_AD_ACCOUNT_ID=        # numeric id(s) from Campaign Manager URL, comma-separated
# LINKEDIN_API_VERSION=202601
# LINKEDIN_VISIBILITY_LOOKBACK_DAYS=30
# LINKEDIN_MIN_IMPRESSIONS=5    # LinkedIn adds ±3/day privacy noise; filter dust

# ── Storage ────────────────────────────────────────────────────────────────────
# Set automatically when you add Vercel Blob storage to the project.
# Locally, leave unset — snapshots are written to data/snapshot.json instead.
# BLOB_READ_WRITE_TOKEN=
